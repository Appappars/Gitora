{
  "name": "gitora",
  "private": true,
  "version": "0.1.9",
  "description": "Desktop GitHub history graph",
  "author": "Gitora",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "test:electron": "electron scripts/smoke-electron.cjs",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "electron:build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-electron.ps1"
  },
  "dependencies": {
    "ignore": "^7.0.5",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^6.1.0",
    "vitest": "^4.1.9",
    "wait-on": "^8.0.1"
  }
}

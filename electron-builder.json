{
  "appId": "com.gitora.app",
  "productName": "Gitora",
  "directories": {
    "output": "outputs/release"
  },
  "files": [
    "dist/**/*",
    "electron/**/*"
  ],
  "win": {
    "target": "nsis",
    "icon": "build/icon.png"
  },
  "mac": {
    "target": "dmg"
  },
  "linux": {
    "target": "AppImage",
    "icon": "build/icon.png"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}
